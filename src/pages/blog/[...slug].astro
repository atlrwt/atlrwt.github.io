---
import { getCollection, render } from "astro:content";
import Comments from "../../components/comments/CommentsPlaceholder.astro";
import BaseLayout from "../../layouts/BaseLayout.astro";
import { isPublished, tagToSlug } from "../../lib/content";
import { withBase } from "../../lib/url";

export async function getStaticPaths() {
  const posts = await getCollection("blog", ({ data }) => isPublished(data));
  return posts.map((post) => ({
    params: { slug: post.id },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content, headings } = await render(post);
---

<BaseLayout title={`${post.data.title} - Shengjie`} description={post.data.description}>
  <article class="container prose">
    <header>
      <p class="meta">
        <time datetime={post.data.publishDate.toISOString()}>
          {post.data.publishDate.toLocaleDateString("zh-CN")}
        </time>
      </p>
      <h1>{post.data.title}</h1>
      <p>{post.data.description}</p>
      {
        post.data.categories.length > 0 && (
          <p class="meta">分类：{post.data.categories.join(" / ")}</p>
        )
      }
      <div class="tags">
        {post.data.tags.map((tag) => <a class="tag" href={withBase(`/tags/${tagToSlug(tag)}/`)}>{tag}</a>)}
      </div>
    </header>

    {
      headings.length > 1 && (
        <nav aria-label="Table of contents">
          <h2>目录</h2>
          <ol>
            {headings.map((heading) => (
              <li>
                <a href={`#${heading.slug}`}>{heading.text}</a>
              </li>
            ))}
          </ol>
        </nav>
      )
    }

    <Content />
    <Comments />
  </article>
</BaseLayout>
