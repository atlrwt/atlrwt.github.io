---
import PostCard from "../components/content/PostCard.astro";
import ProjectCard from "../components/projects/ProjectCard.astro";
import BaseLayout from "../layouts/BaseLayout.astro";
import { getBlogPosts, getProjects } from "../lib/content";
import { withBase } from "../lib/url";

const posts = (await getBlogPosts()).slice(0, 3);
const projects = (await getProjects()).slice(0, 3);
---

<BaseLayout title="Shengjie - AI Project Manager & Technical Builder">
  <section class="page-head">
    <div class="container">
      <h1>AI project management, engineering notes, and reusable systems.</h1>
      <p>
        I write about AI engineering, knowledge management, productized workflows,
        and the projects behind them.
      </p>
      <div class="button-row" style="margin-top: 24px;">
        <a class="button" href={withBase("/blog/")}>Read blog</a>
        <a class="button secondary" href={withBase("/projects/")}>View projects</a>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container stack">
      <h2>Latest writing</h2>
      <div class="grid">
        {posts.map((post) => <PostCard post={post} />)}
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container stack">
      <h2>Selected projects</h2>
      <div class="grid">
        {projects.map((project) => <ProjectCard project={project} />)}
      </div>
    </div>
  </section>
</BaseLayout>
